{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SQL Studio",
  "version": "0.1.1",
  "identifier": "ch.gonnet.sqlstudio",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SQL Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/engine"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
